{
  "name": "@arseno25/comet",
  "version": "1.0.0",
  "description": "AI commit message assistant with secure diff redaction and modern terminal UX.",
  "author": "arseno25",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arseno25/comet.git"
  },
  "bugs": {
    "url": "https://github.com/arseno25/comet/issues"
  },
  "homepage": "https://github.com/arseno25/comet#readme",
  "bin": {
    "comet": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.8.0",
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "cli",
    "git",
    "commit",
    "conventional-commits",
    "opencommit",
    "ai"
  ],
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "boxen": "^8.0.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "openai": "^6.34.0",
    "picomatch": "^4.0.4",
    "yoctocolors": "^2.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.2.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
